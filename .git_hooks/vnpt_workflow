    echo "║          Single Source of Truth: DEVELOPMENT_STATUS.md   ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

print_success() { echo -e "${GREEN}✅ $1${NC}"; }
print_error()   { echo -e "${RED}❌ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠️  $1${NC}"; }
print_info()    { echo -e "${BLUE}ℹ️  $1${NC}"; }
print_stage()   { echo -e "${CYAN}[$1]${NC} $2"; }

# Normalize feature name → snake_case lowercase
normalize_name() {
    local name="$1"
    if [[ -z "$name" ]]; then echo ""; return 1; fi
    echo "$name" | sed 's/ /_/g' | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9_]//g'
}

# Convert snake_case → PascalCase
to_pascal_case() {
    local s="$1"
    echo "$s" | sed 's/_/ /g' | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) substr($i,2)} 1' | sed 's/ //g'
}

# Today YYYY-MM-DD
today() { date '+%Y-%m-%d'; }

# ═══════════════════════════════════════════════════════════
# STATUS VALIDATION + TRANSITIONS
# ═══════════════════════════════════════════════════════════
validate_stage() {
    case "$1" in
        dev|development)    echo "dev" ;;
        review)             echo "review" ;;
        fix|fixing|bug)     echo "fix" ;;
        *) print_error "Stage không hợp lệ: $1 (chỉ: dev, review, fix)"; return 1 ;;
    esac
}

status_emoji() {
    case "$1" in
        pending)            echo "⏳ Pending" ;;
        progress|running)   echo "🔄 In Progress" ;;
        done|complete)      echo "✅ Done" ;;
        no_bug|clean)       echo "🧼 No Bug" ;;
        failed|error)       echo "❌ Failed" ;;
        *)                  echo "❓ $1" ;;
    esac
}

# Valid transitions table
is_valid_transition() {
    local from_stage="$1" from_status="$2" to_stage="$3" to_status="$4"
    # From any → pending is always valid (reset)
    if [[ "$to_status" == "pending" ]]; then echo "yes"; return; fi

    case "$from_stage:$from_status" in
        dev:pending)        [[ "$to_stage:$to_status" == "dev:progress" ]] && echo "yes" || echo "no" ;;
        dev:progress)       [[ "$to_stage:$to_status" == "dev:done" ]] && echo "yes" || echo "no" ;;
        dev:done)           [[ "$to_stage:$to_status" == "review:progress" || "$to_stage:$to_status" == "review:pending" ]] && echo "yes" || echo "no" ;;
        review:pending)     [[ "$to_stage:$to_status" == "review:progress" ]] && echo "yes" || echo "no" ;;
        review:progress)    [[ "$to_stage:$to_status" == "review:no_bug" || "$to_stage:$to_status" == "review:failed" ]] && echo "yes" || echo "no" ;;
        review:no_bug)      [[ "$to_stage:$to_status" == "review:done" ]] && echo "yes" || echo "no" ;;
        review:done)        echo "no" ;;  # END
        review:failed)      [[ "$to_stage:$to_status" == "fix:progress" || "$to_stage:$to_status" == "fix:pending" ]] && echo "yes" || echo "no" ;;
        fix:pending)        [[ "$to_stage:$to_status" == "fix:progress" ]] && echo "yes" || echo "no" ;;
        fix:progress)       [[ "$to_stage:$to_status" == "fix:done" ]] && echo "yes" || echo "no" ;;
        fix:done)           [[ "$to_stage:$to_status" == "review:pending" ]] && echo "yes" || echo "no" ;;
        *)                  echo "yes" ;;  # permissive default
    esac
}

# ═══════════════════════════════════════════════════════════
# FIND STATUS FILE
# ═══════════════════════════════════════════════════════════
find_status_file() {
    local feature="$1"
    local found=$(find "$PROJECT_ROOT" -path "*/$feature/DEVELOPMENT_STATUS.md" -type f 2>/dev/null | head -1)
    echo "$found"
}

# Read current status from file
read_current_status() {
    local status_file="$1"
    local stage="$2"
    python3 - "$status_file" "$stage" <<'PYEOF'
import sys, re
path, stage = sys.argv[1], sys.argv[2]
try:
    with open(path) as f:
        content = f.read()
    # Match row: | Development | ⏳ Pending | 2026-06-14 | ... |
    # Map stage names
    stage_map = {"dev": ["Development", "Dev"], "review": ["Review"], "fix": ["Fix Bug", "Fix"]}
    names = stage_map.get(stage, [stage.title()])
    for name in names:
        pattern = r'\|\s*' + re.escape(name) + r'\s*\|\s*([^\|]+)\|'
        m = re.search(pattern, content)
        if m:
            cell = m.group(1).strip()
            # Parse status (e.g. "⏳ Pending" or "🔄 In Progress")
            for s in ["pending", "progress", "done", "failed", "no_bug"]:
                if s in cell.lower():
                    print(s)
                    sys.exit(0)
    print("pending")
except FileNotFoundError:
    print("pending")
PYEOF
}

# ═══════════════════════════════════════════════════════════
# CMD: CREATE
# ═══════════════════════════════════════════════════════════
cmd_create() {
    local feature_name=""
    local feature_path=""
    local srs_file=""
    local figma_url=""
    local postman_collection=""
    local module_path=""

    # Parse args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --srs)     srs_file="$2"; shift 2 ;;
            --figma)   figma_url="$2"; shift 2 ;;
            --postman) postman_collection="$2"; shift 2 ;;
            --module)  module_path="$2"; shift 2 ;;
            -*)        print_error "Unknown flag: $1"; return 1 ;;
            *)
                if [[ -z "$feature_name" ]]; then feature_name="$1"
                elif [[ -z "$feature_path" ]]; then feature_path="$1"
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$feature_name" ]]; then
        print_error "Usage: vnpt_workflow create <feature_name> [path] [--srs <file>] [--figma <url>] [--postman <name>] [--module <path>]"
        echo ""
        echo "Examples:"
        echo "  vnpt_workflow create user_profile"
        echo "  vnpt_workflow create list_event vna_default/lib/event_screens \\"
        echo "    --srs SRS_Event.md \\"
        echo "    --figma 'https://figma.com/design/.../?node-id=74-7479' \\"
        echo "    --postman MobileEventAiGen \\"
        echo "    --module vna_office/lib/screens"
        return 1
    fi

    local name_lower=$(normalize_name "$feature_name")
    local name_upper=$(to_pascal_case "$name_lower")
    local name_display=$(echo "$feature_name" | sed 's/_/ /g')

    # ── Auto-detect module path từ SRS path nếu không có --module ──
    if [[ -z "$module_path" && -n "$srs_file" ]]; then
        # SRS path dạng: vna_office/lib/screens/ai_gen/srs/list_task/SRS_LIST_TASK.md
        # → module = vna_office/lib/screens/ai_gen
        module_path=$(SRS_FILE="$srs_file" python3 <<'PYEOF'
import os, re
path = os.environ.get("SRS_FILE", "")
m = re.search(r'^(.*?)/(?:srs|specs?)/', path)
if m:
    print(m.group(1))
else:
    print(re.sub(r'/[^/]+\.(md|markdown)$', '', path))
PYEOF
)
    fi

    # Nếu không có --module mà có module từ SRS → dùng nó làm feature_path
    if [[ -z "$feature_path" && -n "$module_path" ]]; then
        feature_path="$module_path"
    fi

    # Default path nếu vẫn chưa có
    if [[ -z "$feature_path" ]]; then
        if [[ -n "$module_path" ]]; then
            feature_path="$module_path"
        else
            feature_path="${WC_FEATURES_PATH:-lib/features}"
        fi
    fi

    local feature_dir="$PROJECT_ROOT/$feature_path/$name_lower"

    print_banner
    echo -e "${BOLD}Feature:${NC} $name_display"
    echo -e "${BOLD}Path:${NC} $feature_dir"
    echo ""

    # Show 3 sources
    echo -e "${BOLD}📥 Input Sources:${NC}"
    if [[ -n "$srs_file" ]]; then
        print_stage "SRS" "File: $srs_file"
    else
        echo -e "${YELLOW}   SRS: not provided${NC}"
    fi
    if [[ -n "$figma_url" ]]; then
        print_stage "FIGMA" "URL: $figma_url"
    else
        echo -e "${YELLOW}   Figma: not provided${NC}"
    fi
    if [[ -n "$postman_collection" ]]; then
        print_stage "POSTMAN" "Collection: $postman_collection"
    else
        echo -e "${YELLOW}   Postman: not provided${NC}"
    fi
    echo ""

    # Check exists
    if [[ -d "$feature_dir" ]]; then
        print_warning "Feature '$name_lower' đã tồn tại!"
        if [[ -f "$feature_dir/DEVELOPMENT_STATUS.md" ]]; then
            print_info "DEVELOPMENT_STATUS.md hiện tại:"
            cat "$feature_dir/DEVELOPMENT_STATUS.md"
        fi
        return 1
    fi

    # Create dirs
    print_stage "CREATE" "Creating folder structure..."
    mkdir -p "$feature_dir/component"
    mkdir -p "$feature_dir/model"
    mkdir -p "$feature_dir/widget"
    mkdir -p "$feature_dir/assets"
    mkdir -p "$feature_dir/.vnpt_cache"
    print_success "Folder created"

    # ── Parse Figma URL → fileKey + nodeId ──
    local figma_file_key=""
    local figma_node_id=""
    if [[ -n "$figma_url" ]]; then
        local parsed=$(FIGMA_URL="$figma_url" python3 <<'PYEOF'
import os, re, json
url = os.environ.get("FIGMA_URL", "")
fk, nid = "", ""
m = re.search(r'/design/([A-Za-z0-9]+)/.*?[?&]node-id=([0-9]+[-:][0-9]+)', url)
if m:
    fk = m.group(1)
    nid = m.group(2).replace("-", ":")
else:
    m = re.search(r'/(?:file|design)/([A-Za-z0-9]+)', url)
    if m: fk = m.group(1)
    m = re.search(r'node-id=([0-9]+[-:][0-9]+)', url)
    if m: nid = m.group(1).replace("-", ":")
print(json.dumps({"file_key": fk, "node_id": nid}))
PYEOF
)
        figma_file_key=$(echo "$parsed" | python3 -c "import sys,json;print(json.load(sys.stdin)['file_key'])")
        figma_node_id=$(echo "$parsed" | python3 -c "import sys,json;print(json.load(sys.stdin)['node_id'])")
        print_stage "FIGMA" "Parsed: fileKey=$figma_file_key, nodeId=$figma_node_id"
    fi

    # ── Save sources.json (đầy đủ + parsed data) ──
    print_stage "CACHE" "Saving sources.json..."
    cat > "$feature_dir/.vnpt_cache/sources.json" <<EOF
{
  "feature": "$name_lower",
  "display_name": "$name_display",
  "module": "$module_path",
  "created": "$(today)",
  "srs": {
    "file": "$srs_file",
    "provided": $([ -n "$srs_file" ] && echo "true" || echo "false")
  },
  "figma": {
    "url": "$figma_url",
    "file_key": "$figma_file_key",
    "node_id": "$figma_node_id",
    "provided": $([ -n "$figma_url" ] && echo "true" || echo "false")
  },
  "postman": {
    "collection": "$postman_collection",
    "provided": $([ -n "$postman_collection" ] && echo "true" || echo "false")
  }
}
EOF

#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# VNPT WORKFLOW CLI v2.0 — Refactored
# Single source of truth: DEVELOPMENT_STATUS.md (Markdown)
# Thống nhất commands, parse Figma URL, parse module path,
# validate state transitions, sửa file Markdown thực sự.
# ═══════════════════════════════════════════════════════════════

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

# ═══════════════════════════════════════════════════════════
# CONFIG
# ═══════════════════════════════════════════════════════════
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ═══════════════════════════════════════════════════════════
# LOAD .workflow_config — auto-find từ script dir → project root
# Khi đổi dự án: cập nhật .workflow_config tại project root
# ═══════════════════════════════════════════════════════════
find_wc_config() {
    local dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/.workflow_config" ]]; then
            echo "$dir/.workflow_config"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    return 1
}

load_wc_config() {
    local cfg
    cfg=$(find_wc_config) || {
        echo "WARN: .workflow_config not found" >&2
        return 1
    }
    # shellcheck source=/dev/null
    source "$cfg" 2>/dev/null || {
        echo "WARN: Failed to source $cfg" >&2
    }
}

# Load immediately
load_wc_config

# Project root resolution
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

RULES_DIR="$PROJECT_ROOT/.cursor/rules"


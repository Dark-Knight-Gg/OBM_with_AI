# ═══════════════════════════════════════════════════════════
# CMD: UPDATE (SỬA FILE MARKDOWN THỰC SỰ)
# ═══════════════════════════════════════════════════════════
cmd_update() {
    local feature="$1"
    local stage="$2"
    local status_input="$3"
    shift 3 2>/dev/null || true
    local note="$*"

    if [[ -z "$feature" || -z "$stage" || -z "$status_input" ]]; then
        print_error "Usage: vnpt_workflow update <feature> <stage> <status> [note]"
        echo ""
        echo "Stages: dev | review | fix"
        echo "Status: pending | progress | done | no_bug | failed"
        return 1
    fi

    local name_lower=$(normalize_name "$feature")
    local stage_valid=$(validate_stage "$stage")
    local status_text=$(status_emoji "$status_input")
    local today_str=$(today)
    local now_ts=$(date '+%Y-%m-%d %H:%M')

    local status_file=$(find_status_file "$name_lower")
    if [[ -z "$status_file" ]]; then
        print_error "Không tìm thấy feature '$name_lower'!"
        print_info "Tạo mới: vnpt_workflow create $name_lower"
        return 1
    fi

    # ── Validate transition ──
    local current_status=$(read_current_status "$status_file" "$stage_valid")
    local validation=$(is_valid_transition "$stage_valid" "$current_status" "$stage_valid" "$status_input")
    if [[ "$validation" == "no" ]]; then
        print_warning "Transition không hợp lệ: $stage_valid:$current_status → $stage_valid:$status_input"
        print_info "Đã ghi đè (permissive mode). State machine chỉ là guidance."
    fi

    # ── Stage display name trong bảng ──
    local stage_display
    case "$stage_valid" in
        dev)    stage_display="Development" ;;
        review) stage_display="Review" ;;
        fix)    stage_display="Fix Bug" ;;
    esac

    # ── SỬA FILE DEVELOPMENT_STATUS.md (bằng Python — chính xác hơn sed) ──
    python3 - "$status_file" "$stage_display" "$status_text" "$today_str" "$note" "$now_ts" "$stage_valid" <<'PYEOF'
import sys, re

path = sys.argv[1]
stage_display = sys.argv[2]
status_text = sys.argv[3]
today_str = sys.argv[4]
note = sys.argv[5]
now_ts = sys.argv[6]
stage_valid = sys.argv[7]

with open(path) as f:
    content = f.read()

# 1) Update bảng Trạng Thái — thay thế dòng chứa stage_display
lines = content.split("\n")
new_lines = []
updated = False
for line in lines:
    if re.match(r'^\|\s*' + re.escape(stage_display) + r'\s*\|', line):
        cells = [c.strip() for c in line.strip().strip('|').split('|')]
        if len(cells) >= 4:
            cells[1] = status_text
            cells[2] = today_str
            cells[3] = note or '-'
            line = '| ' + ' | '.join(cells) + ' |'
            updated = True
    new_lines.append(line)

if not updated:
    print(f"WARN: Không tìm thấy row cho stage '{stage_display}'", file=sys.stderr)

content = "\n".join(new_lines)

# 2) Update Last Updated field — giữ đúng 1 space trước/sau value
content = re.sub(
    r'(\|\s*Last Updated\s*\|\s*)[^|]*(\s*\|)',
    r'\g<1> ' + today_str + r'\g<2>',
    content, count=1
)
# Normalize: " |  value |" → " | value |" (fix double space)
content = re.sub(
    r'(\|\s*Last Updated\s*\|\s*) +(2026-\d{2}-\d{2})(\s*\|)',
    r'\g<1>\g<2>\g<3>',
    content, count=1
)

# 3) Append Changelog
changelog_row = f"| {today_str} | {stage_valid.title()} | {status_text} |"
if note:
    changelog_row += f" {note} |"
else:
    changelog_row += " |"
changelog_row += " Agent |"

# Tìm dòng cuối của bảng Changelog (dòng bắt đầu "|") và thêm vào sau
# Đơn giản: append vào cuối file trước "---" nếu có
if "## 📝 Changelog" in content:
    # Tìm vị trí bảng Changelog và append row mới vào sau dòng header + separator
    parts = content.split("## 📝 Changelog", 1)
    if len(parts) == 2:
        # Tìm dòng cuối cùng có dạng "| ... |" trong phần 2
        after = parts[1]
        lines = after.split("\n")
        # Tìm dòng index cuối cùng match pattern table row
        last_idx = -1
        for i, line in enumerate(lines):
            if re.match(r'^\|\s*\|?\s*[^|]*\s*\|', line):
                last_idx = i
        if last_idx >= 0:
            lines.insert(last_idx + 1, changelog_row)
            after = "\n".join(lines)
        content = parts[0] + "## 📝 Changelog" + after

with open(path, "w") as f:
    f.write(content)

print(f"UPDATED: stage={stage_display} status={status_text}")
PYEOF

    print_success "Updated file: $status_file"
    print_info "Stage: $stage_display → $status_text"
    print_info "Date: $today_str"
    [[ -n "$note" ]] && print_info "Note: $note"
    echo ""

    # Show bảng Trạng Thái sau update
    echo -e "${BOLD}📋 Current status:${NC}"
    grep -A 5 "Trạng Thái" "$status_file" | head -8
}

# ═══════════════════════════════════════════════════════════
# CMD: REVIEW (mark progress + guide agent)
# ═══════════════════════════════════════════════════════════
cmd_review() {
    local feature="$1"
    if [[ -z "$feature" ]]; then
        print_error "Usage: vnpt_workflow review <feature>"
        return 1
    fi

    local name_lower=$(normalize_name "$feature")
    print_banner
    print_stage "REVIEW" "Feature: $name_lower"

    # Mark review progress (chỉ update status)
    cmd_update "$name_lower" review progress "Bắt đầu review"
    echo ""

    # Tìm file path
    local status_file=$(find_status_file "$name_lower")
    if [[ -z "$status_file" ]]; then
        print_error "Không tìm thấy feature '$name_lower'!"
        return 1
    fi

    local feature_dir=$(dirname "$status_file")

    echo -e "${BOLD}🔍 Review checklist:${NC}"
    echo "  Feature dir: $feature_dir"
    echo "  Review criteria: $RULES_DIR/review/review-criteria.mdc"
    echo ""

    # Optionally run auto-review.sh if exists
    local auto_review="$SCRIPT_DIR/auto_review.sh"
    if [[ -x "$auto_review" ]]; then
        print_stage "AUTO" "Running auto_review.sh..."
        "$auto_review" "$feature_dir" "$name_lower" || true
    else
        echo "📋 Hãy check 12+ tiêu chí trong review-criteria.mdc:"
        echo "  - Scaffold vs BaseScreen"
        echo "  - Hardcoded colors/strings/URLs"
        echo "  - SelectorBase vs ConsumerBase"
        echo "  - mounted check, dispose, etc."
    fi
    echo ""

    echo -e "${BOLD}Sau review:${NC}"
    echo "  Nếu PASS: ./vnpt_workflow update $name_lower review no_bug 'Clean code'"
    echo "             ./vnpt_workflow update $name_lower review done"
    echo "  Nếu FAIL: ./vnpt_workflow update $name_lower review failed 'N bugs'"
    echo "             ./vnpt_workflow update $name_lower fix progress"
}

# ═══════════════════════════════════════════════════════════
# CMD: FIX (mark progress + guide agent)
# ═══════════════════════════════════════════════════════════
cmd_fix() {
    local feature="$1"
    if [[ -z "$feature" ]]; then
        print_error "Usage: vnpt_workflow fix <feature>"
        return 1
    fi

    local name_lower=$(normalize_name "$feature")
    print_banner
    print_stage "FIX" "Feature: $name_lower"

    cmd_update "$name_lower" fix progress "Bắt đầu fix"
    echo ""

    local status_file=$(find_status_file "$name_lower")
    if [[ -z "$status_file" ]]; then
        print_error "Không tìm thấy feature '$name_lower'!"
        return 1
    fi

    echo -e "${BOLD}📋 Bugs Log:${NC}"
    grep -A 20 "🐛 Bugs Log" "$status_file" | head -25
    echo ""

    echo -e "${BOLD}Sau fix:${NC}"
    echo "  ./vnpt_workflow update $name_lower fix done 'Đã fix N bugs'"
    echo "  ./vnpt_workflow update $name_lower review pending 'Reset để review lại'"
}

# ═══════════════════════════════════════════════════════════
# CMD: STATUS
# ═══════════════════════════════════════════════════════════
cmd_status() {
    local feature="$1"

    if [[ -n "$feature" ]]; then
        local name_lower=$(normalize_name "$feature")
        local status_file=$(find_status_file "$name_lower")
        if [[ -z "$status_file" ]]; then
            print_error "Không tìm thấy feature '$name_lower'!"
            return 1
        fi
        echo -e "${BOLD}📋 Status for: ${name_lower}${NC}"
        echo ""
        cat "$status_file"
    else
        # List all features + bảng summary
        print_banner
        local status_files=$(find "$PROJECT_ROOT" -name "DEVELOPMENT_STATUS.md" -type f 2>/dev/null)
        if [[ -z "$status_files" ]]; then
            print_warning "Chưa có feature nào!"
            echo "Tạo: ./vnpt_workflow create <feature_name>"
            return 0
        fi

        echo -e "${BOLD}📁 Features Status Overview${NC}"
        printf "${CYAN}%-30s %-15s %-15s %-15s${NC}\n" "Feature" "Dev" "Review" "Fix"
        echo "────────────────────────────────────────────────────────────────"

        for file in $status_files; do
            local dir=$(dirname "$file")
            local name=$(basename "$dir")
            local dev_status=$(read_current_status "$file" "dev")
            local review_status=$(read_current_status "$file" "review")
            local fix_status=$(read_current_status "$file" "fix")
            local dev_label=$(status_emoji "$dev_status" 2>/dev/null || echo "⏳ Pending")
            local review_label=$(status_emoji "$review_status" 2>/dev/null || echo "⏳ Pending")
            local fix_label=$(status_emoji "$fix_status" 2>/dev/null || echo "⏳ Pending")
            printf "%-30s %-15s %-15s %-15s\n" "$name" "$dev_label" "$review_label" "$fix_label"
        done
        echo ""
    fi
}

# ═══════════════════════════════════════════════════════════
# CMD: LIST
# ═══════════════════════════════════════════════════════════
cmd_list() {
    cmd_status ""
}

# ═══════════════════════════════════════════════════════════
# CMD: HELP
# ═══════════════════════════════════════════════════════════
cmd_help() {
    print_banner
    echo -e "${BOLD}USAGE:${NC}"
    echo "  vnpt_workflow <command> [arguments]"
    echo ""
    echo -e "${BOLD}COMMANDS:${NC}"
    echo "  create <name> [path] [--srs <file>] [--figma <url>] [--postman <name>] [--module <path>]"
    echo "  status [feature]              Xem trạng thái feature (hoặc tất cả)"
    echo "  update <feature> <stage> <status> [note]"
    echo "                               Update status + SỬA file DEVELOPMENT_STATUS.md"
    echo "  review <feature>              Chạy code review"
    echo "  fix <feature>                 Fix bugs (loop review)"
    echo "  list                          List tất cả features"
    echo "  help                          Hiển thị help này"
    echo ""
    echo -e "${BOLD}STAGES:${NC} dev | review | fix"
    echo -e "${BOLD}STATUS:${NC} pending ⏳ | progress 🔄 | done ✅ | no_bug 🧼 | failed ❌"
    echo ""
    echo -e "${BOLD}CREATE FLAGS (3-SOURCE WORKFLOW):${NC}"
    echo "  --srs <file>        SRS markdown file path"
    echo "  --figma <url>       Figma URL với node-id"
    echo "  --postman <name>    Postman collection name"
    echo "  --module <path>     Module path (VD: vna_office/lib/screens/ai_gen)"
    echo ""
    echo -e "${BOLD}EXAMPLES:${NC}"
    echo "  vnpt_workflow create user_profile"
    echo "  vnpt_workflow create list_event vna_default/lib/event_screens \\"
    echo "    --srs SRS_Event.md \\"
    echo "    --figma 'https://figma.com/design/.../?node-id=74-7479' \\"
    echo "    --postman MobileEventAiGen"
}

# ═══════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════
COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
    create|c)  cmd_create "$@" ;;
    status|s)  cmd_status "${1:-}" ;;
    update|u)  cmd_update "$@" ;;
    review|r)  cmd_review "${1:-}" ;;
    fix|f)     cmd_fix "${1:-}" ;;
    list|l)    cmd_list ;;
    help|h|--help|-h) cmd_help ;;
    *)
        print_error "Unknown command: $COMMAND"
        echo "Gõ 'vnpt_workflow help' để xem hướng dẫn."
        exit 1
        ;;
esac

### Bước 8: AI Review-Loop (Tự động, KHÔNG chờ user gõ)

**Trigger:** Sau khi dev done, Agent phải TỰ ĐỘNG chạy review loop.

**MAX_ITERATIONS = 3**

#### Loop chính

```python
iteration = 0
has_bug = True

while has_bug and iteration < MAX_ITERATIONS:
    iteration += 1
    print(f"🔍 Review iteration {iteration}/{MAX_ITERATIONS}")

    # ── 8a. Update status → review progress ────────────────
    ./vnpt_workflow update <tên> review progress

    # ── 8b. Chạy auto_review.sh ───────────────────────────
    script_result = shell(
        ".git_hooks/auto_review.sh <feature_dir> <feature_name>",
        working_directory=PROJECT_ROOT
    )
    script_pass = (script_result.exit_code == 0)

    # ── 8c. Đọc report + phân tích bugs ───────────────────
    report_path = glob.glob("<feature_dir>/.vnpt_cache/report_*.md")[-1]
    report = Read(report_path)
    bugs_script = parse_bugs_from_report(report)
    bugs_ai = ai_semantic_review(<feature_dir>)   # 8d

    all_bugs = bugs_script + bugs_ai

    # ── 8e. Fix bugs ────────────────────────────────────────
    if all_bugs:
        ./vnpt_workflow update <tên> review failed
        ./vnpt_workflow update <tên> fix progress

        for bug in all_bugs:
            apply_fix(bug)   # xem bảng fix bên dưới

        ./vnpt_workflow update <tên> fix done

    # ── 8f. Verify bằng dart analyze ─────────────────────
    verify = shell("dart analyze <feature_dir>", ...)
    if verify.exit_code != 0:
        for error in verify.errors:
            apply_fix(error)

    # ── 8g. Confirm bằng auto_review.sh lại ─────────────
    confirm_result = shell(
        ".git_hooks/auto_review.sh <feature_dir> <feature_name>",
        working_directory=PROJECT_ROOT
    )
    script_pass = (confirm_result.exit_code == 0)

    if script_pass and len(bugs_ai) == 0:
        has_bug = False
        ./vnpt_workflow update <tên> review no_bug
        ./vnpt_workflow update <tên> review done
        print("✅ Review PASSED")
        break
    else:
        ./vnpt_workflow update <tên> review pending
        continue

if iteration >= MAX_ITERATIONS and has_bug:
    print("⚠️ Sau 3 vòng vẫn còn bug. Cần user hỗ trợ.")
    ./vnpt_workflow update <tên> review blocked
```


### Rule 6: Provider KHÔNG declare lại `{{STATE_TYPE}}` field

> Variables: `{{PROVIDER_BASE}}`, `{{STATE_TYPE}}`, `{{M_SHOW_LOADING}}`, `{{M_SHOW_LOADED}}`, `{{M_SHOW_ERROR}}`, `{{M_SHOW_NO_DATA}}`

```dart
// ❌ SAI — Trùng với base đã có
class XxxProvider extends {{PROVIDER_BASE}}<XxxService> {
  {{STATE_TYPE}} status = {{STATE_TYPE}}.none;  // ❌ trùng
}

// ✅ ĐÚNG — Dùng helper của base, không cần declare field
class XxxProvider extends {{PROVIDER_BASE}}<XxxService> {
  List<XxxModel> items = const [];

  {{ASYNC_METHOD}} fetch() async {
    {{M_SHOW_LOADING}};
    try {
      final res = await service.getItems();
      items = res.data ?? const [];
      items.isEmpty ? {{M_SHOW_NO_DATA}} : {{M_SHOW_LOADED}};
    } on {{DIO_EXCEPTION}} catch (e) {
      errorMessage = e.message;
      {{M_SHOW_ERROR}};
    } catch (e) {
      errorMessage = e.toString();
      {{M_SHOW_ERROR}};
    }
  }
}
```

